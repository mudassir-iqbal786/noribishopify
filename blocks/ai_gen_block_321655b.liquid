{% doc %}
  @prompt
    Create a full-width product image section with the following features: 4:5 portrait aspect ratio for all images, swipe carousel with dots indicator for navigating between product images, overlay icons for wishlist (heart) and share functionality positioned in the top-right corner of the image, and images that are centered and properly fitted without incorrect cropping (using object-fit: cover centered). The section should be mobile-optimized and match a fairy/costume product page aesthetic.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-gallery-{{ ai_gen_id }} {
    width: 100%;
    display: block;
    position: relative;
  }

  .ai-product-gallery__container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
  }

  .ai-product-gallery__carousel-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .ai-product-gallery__track-{{ ai_gen_id }} {
    display: flex;
    height: 100%;
    transition: transform 0.3s ease;
  }

  .ai-product-gallery__slide-{{ ai_gen_id }} {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .ai-product-gallery__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .ai-product-gallery__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-product-gallery__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-product-gallery__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    right: 16px;
    display: flex;
    gap: 8px;
    z-index: 10;
  }

  .ai-product-gallery__icon-button-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.icon_background }};
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-product-gallery__icon-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.icon_hover_background }};
    transform: scale(1.1);
  }

  .ai-product-gallery__icon-button-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
    stroke: {{ block.settings.icon_color }};
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-product-gallery__icon-button-{{ ai_gen_id }}:hover svg {
    stroke: {{ block.settings.icon_hover_color }};
  }

  .ai-product-gallery__icon-button-{{ ai_gen_id }}--active svg {
    fill: {{ block.settings.icon_color }};
  }

  .ai-product-gallery__icon-button-{{ ai_gen_id }}--active:hover svg {
    fill: {{ block.settings.icon_hover_color }};
  }

  .ai-product-gallery__dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 10;
  }

  .ai-product-gallery__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: 0.5;
    padding: 0;
  }

  .ai-product-gallery__dot-{{ ai_gen_id }}--active {
    opacity: 1;
    background-color: {{ block.settings.dot_active_color }};
  }

  .ai-product-gallery__dot-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-product-gallery__overlay-{{ ai_gen_id }} {
      top: 12px;
      right: 12px;
      gap: 6px;
    }

    .ai-product-gallery__dots-{{ ai_gen_id }} {
      bottom: 12px;
      gap: 6px;
    }
  }
{% endstyle %}

<product-gallery-{{ ai_gen_id }}
  class="ai-product-gallery-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-product-gallery__container-{{ ai_gen_id }}">
    <div class="ai-product-gallery__carousel-{{ ai_gen_id }}">
      <div class="ai-product-gallery__track-{{ ai_gen_id }}">
        {% if product.images.size > 0 %}
          {% for image in product.images %}
            <div class="ai-product-gallery__slide-{{ ai_gen_id }}">
              <img
                src="{{ image | image_url: width: 1000 }}"
                alt="{{ image.alt | escape }}"
                class="ai-product-gallery__image-{{ ai_gen_id }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                width="{{ image.width }}"
                height="{{ image.height }}"
              >
            </div>
          {% endfor %}
        {% else %}
          <div class="ai-product-gallery__slide-{{ ai_gen_id }}">
            <div class="ai-product-gallery__placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    {% if block.settings.show_wishlist or block.settings.show_share %}
      <div class="ai-product-gallery__overlay-{{ ai_gen_id }}">
        {% if block.settings.show_wishlist %}
          <button
            class="ai-product-gallery__icon-button-{{ ai_gen_id }} ai-product-gallery__wishlist-{{ ai_gen_id }}"
            aria-label="Add to wishlist"
            data-wishlist-button
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
            </svg>
          </button>
        {% endif %}

        {% if block.settings.show_share %}
          <button
            class="ai-product-gallery__icon-button-{{ ai_gen_id }} ai-product-gallery__share-{{ ai_gen_id }}"
            aria-label="Share product"
            data-share-button
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <circle cx="18" cy="5" r="3"></circle>
              <circle cx="6" cy="12" r="3"></circle>
              <circle cx="18" cy="19" r="3"></circle>
              <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
              <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
            </svg>
          </button>
        {% endif %}
      </div>
    {% endif %}

    {% if product.images.size > 1 %}
      <div class="ai-product-gallery__dots-{{ ai_gen_id }}">
        {% for image in product.images %}
          <button
            class="ai-product-gallery__dot-{{ ai_gen_id }} {% if forloop.first %}ai-product-gallery__dot-{{ ai_gen_id }}--active{% endif %}"
            aria-label="Go to slide {{ forloop.index }}"
            data-dot-index="{{ forloop.index0 }}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</product-gallery-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.totalSlides = 0;
        this.startX = 0;
        this.currentX = 0;
        this.isDragging = false;
        this.isWishlisted = false;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-product-gallery__track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-product-gallery__slide-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-product-gallery__dot-{{ ai_gen_id }}');
        this.wishlistButton = this.querySelector('[data-wishlist-button]');
        this.shareButton = this.querySelector('[data-share-button]');
        
        this.totalSlides = this.slides.length;

        if (this.totalSlides > 1) {
          this.setupSwipe();
          this.setupDots();
        }

        if (this.wishlistButton) {
          this.setupWishlist();
        }

        if (this.shareButton) {
          this.setupShare();
        }
      }

      setupSwipe() {
        this.track.addEventListener('touchstart', this.handleTouchStart.bind(this), { passive: true });
        this.track.addEventListener('touchmove', this.handleTouchMove.bind(this), { passive: true });
        this.track.addEventListener('touchend', this.handleTouchEnd.bind(this));

        this.track.addEventListener('mousedown', this.handleMouseDown.bind(this));
        this.track.addEventListener('mousemove', this.handleMouseMove.bind(this));
        this.track.addEventListener('mouseup', this.handleMouseUp.bind(this));
        this.track.addEventListener('mouseleave', this.handleMouseUp.bind(this));
      }

      setupDots() {
        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            this.goToSlide(index);
          });
        });
      }

      setupWishlist() {
        this.wishlistButton.addEventListener('click', () => {
          this.isWishlisted = !this.isWishlisted;
          if (this.isWishlisted) {
            this.wishlistButton.classList.add('ai-product-gallery__icon-button-{{ ai_gen_id }}--active');
          } else {
            this.wishlistButton.classList.remove('ai-product-gallery__icon-button-{{ ai_gen_id }}--active');
          }
        });
      }

      setupShare() {
        this.shareButton.addEventListener('click', () => {
          if (navigator.share) {
            navigator.share({
              title: document.title,
              url: window.location.href
            }).catch(() => {});
          } else {
            const url = window.location.href;
            navigator.clipboard.writeText(url).then(() => {
              const originalLabel = this.shareButton.getAttribute('aria-label');
              this.shareButton.setAttribute('aria-label', 'Link copied!');
              setTimeout(() => {
                this.shareButton.setAttribute('aria-label', originalLabel);
              }, 2000);
            });
          }
        });
      }

      handleTouchStart(e) {
        this.startX = e.touches[0].clientX;
        this.isDragging = true;
      }

      handleTouchMove(e) {
        if (!this.isDragging) return;
        this.currentX = e.touches[0].clientX;
      }

      handleTouchEnd() {
        if (!this.isDragging) return;
        this.isDragging = false;

        const diff = this.startX - this.currentX;
        const threshold = 50;

        if (Math.abs(diff) > threshold) {
          if (diff > 0) {
            this.nextSlide();
          } else {
            this.prevSlide();
          }
        }

        this.startX = 0;
        this.currentX = 0;
      }

      handleMouseDown(e) {
        this.startX = e.clientX;
        this.isDragging = true;
        this.track.style.cursor = 'grabbing';
      }

      handleMouseMove(e) {
        if (!this.isDragging) return;
        this.currentX = e.clientX;
      }

      handleMouseUp() {
        if (!this.isDragging) return;
        this.isDragging = false;
        this.track.style.cursor = 'grab';

        const diff = this.startX - this.currentX;
        const threshold = 50;

        if (Math.abs(diff) > threshold) {
          if (diff > 0) {
            this.nextSlide();
          } else {
            this.prevSlide();
          }
        }

        this.startX = 0;
        this.currentX = 0;
      }

      nextSlide() {
        this.currentIndex = (this.currentIndex + 1) % this.totalSlides;
        this.updateSlide();
      }

      prevSlide() {
        this.currentIndex = (this.currentIndex - 1 + this.totalSlides) % this.totalSlides;
        this.updateSlide();
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateSlide();
      }

      updateSlide() {
        const offset = -this.currentIndex * 100;
        this.track.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('ai-product-gallery__dot-{{ ai_gen_id }}--active');
          } else {
            dot.classList.remove('ai-product-gallery__dot-{{ ai_gen_id }}--active');
          }
        });
      }
    }

    customElements.define('product-gallery-{{ ai_gen_id }}', ProductGallery{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product image gallery",
  "settings": [
    {
      "type": "header",
      "content": "Gallery"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f9f9f9"
    },
    {
      "type": "header",
      "content": "Overlay icons"
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Show wishlist",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_share",
      "label": "Show share",
      "default": true
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 30,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Icon size",
      "default": 40
    },
    {
      "type": "color",
      "id": "icon_background",
      "label": "Icon background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "icon_hover_background",
      "label": "Icon hover background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "icon_hover_color",
      "label": "Icon hover color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Dots indicator"
    },
    {
      "type": "range",
      "id": "dot_size",
      "min": 6,
      "max": 12,
      "step": 2,
      "unit": "px",
      "label": "Dot size",
      "default": 8
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Dot color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "dot_active_color",
      "label": "Active dot color",
      "default": "#111111"
    }
  ],
  "presets": [
    {
      "name": "Product image gallery"
    }
  ]
}
{% endschema %}
