      "id": "tax_text",
      "label": "Tax text",
      "default": "Local taxes included (where applicable)"
    },
    {
      "type": "color",
      "id": "tax_text_color",
      "label": "Tax text color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
