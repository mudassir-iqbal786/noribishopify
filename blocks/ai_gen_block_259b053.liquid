{% doc %}
  @prompt
    Design the mobile product page top section to match Etsy's mobile layout hierarchy. The section should include:
    
    1. Image Section: Full-width product image with 4:5 portrait aspect ratio, swipe carousel with dot indicators, overlay icons for wishlist (heart) and share buttons in the top-right corner, images centered and not cropped incorrectly.
    
    2. Urgency Text: Dynamic small red text above the price showing "In X+ carts" using Shopify product metafield.
    
    3. Price Section (fully dynamic from Shopify data): Large main price, original compare-at price with strikethrough, discount percentage and sale badge.
    
    4. Sale Line: Dynamic green text showing discount percentage and "Limited time sale" - only shown when compare-at price exists.
    
    5. Tax Text: Small muted text: "Local taxes included (where applicable)"
    
    6. Title: Placed below price section, clean lightweight font, max 2-3 lines.
    
    Layout should be clean, minimal, mobile-first. All prices, discount %, and sale indicators must be dynamic using Shopify Liquid variables - no hardcoded values.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-top-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
  }

  .ai-product-top__carousel-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-product-top__carousel-wrapper-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.3s ease;
    touch-action: pan-y;
  }

  .ai-product-top__carousel-slide-{{ ai_gen_id }} {
    flex: 0 0 100%;
    width: 100%;
    aspect-ratio: 4 / 5;
    position: relative;
  }

  .ai-product-top__carousel-slide-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-product-top__carousel-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-top__carousel-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-product-top__carousel-actions-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    right: 12px;
    display: flex;
    gap: 8px;
    z-index: 2;
  }

  .ai-product-top__action-btn-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: {{ block.settings.action_button_bg }};
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    transition: transform 0.2s ease;
  }

  .ai-product-top__action-btn-{{ ai_gen_id }}:active {
    transform: scale(0.95);
  }

  .ai-product-top__action-btn-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    stroke: {{ block.settings.action_button_color }};
    fill: none;
  }

  .ai-product-top__action-btn-{{ ai_gen_id }}.active svg {
    fill: {{ block.settings.action_button_color }};
  }

  .ai-product-top__dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    z-index: 2;
  }

  .ai-product-top__dot-{{ ai_gen_id }} {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.5);
    transition: all 0.3s ease;
  }

  .ai-product-top__dot-{{ ai_gen_id }}.active {
    background-color: #ffffff;
    width: 20px;
    border-radius: 3px;
  }

  .ai-product-top__info-{{ ai_gen_id }} {
    padding: 16px;
  }

  .ai-product-top__urgency-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.urgency_color }};
    margin-bottom: 8px;
    font-weight: 500;
  }

  .ai-product-top__price-section-{{ ai_gen_id }} {
    margin-bottom: 4px;
  }

  .ai-product-top__price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 4px;
  }

  .ai-product-top__price-{{ ai_gen_id }} {
    font-size: 24px;
    font-weight: 600;
    color: {{ block.settings.price_color }};
  }

  .ai-product-top__compare-price-{{ ai_gen_id }} {
    font-size: 18px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
  }

  .ai-product-top__discount-badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    padding: 4px 8px;
    background-color: {{ block.settings.sale_badge_bg }};
    color: {{ block.settings.sale_badge_color }};
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
  }

  .ai-product-top__sale-line-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.sale_text_color }};
    margin-bottom: 8px;
    font-weight: 500;
  }

  .ai-product-top__tax-text-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.tax_text_color }};
    margin-bottom: 12px;
  }

  .ai-product-top__title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 400;
    color: {{ block.settings.title_color }};
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
{% endstyle %}

<product-top-section-{{ ai_gen_id }}
  class="ai-product-top-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-product-top__carousel-{{ ai_gen_id }}">
    <div class="ai-product-top__carousel-wrapper-{{ ai_gen_id }}">
      {% if product.images.size > 0 %}
        {% for image in product.images limit: 5 %}
          <div class="ai-product-top__carousel-slide-{{ ai_gen_id }}">
            <img
              src="{{ image | image_url: width: 800 }}"
              alt="{{ image.alt | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="{{ image.width }}"
              height="{{ image.height }}"
            >
          </div>
        {% endfor %}
      {% else %}
        <div class="ai-product-top__carousel-slide-{{ ai_gen_id }}">
          <div class="ai-product-top__carousel-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-product-top__carousel-actions-{{ ai_gen_id }}">
      {% if block.settings.show_wishlist %}
        <button
          class="ai-product-top__action-btn-{{ ai_gen_id }} ai-product-top__wishlist-btn-{{ ai_gen_id }}"
          aria-label="Add to wishlist"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
        </button>
      {% endif %}

      {% if block.settings.show_share %}
        <button
          class="ai-product-top__action-btn-{{ ai_gen_id }} ai-product-top__share-btn-{{ ai_gen_id }}"
          aria-label="Share product"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="18" cy="5" r="3"></circle>
            <circle cx="6" cy="12" r="3"></circle>
            <circle cx="18" cy="19" r="3"></circle>
            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
            <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
          </svg>
        </button>
      {% endif %}
    </div>

    {% if product.images.size > 1 %}
      <div class="ai-product-top__dots-{{ ai_gen_id }}">
        {% for image in product.images limit: 5 %}
          <span
            class="ai-product-top__dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-index="{{ forloop.index0 }}"
          ></span>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="ai-product-top__info-{{ ai_gen_id }}">
    {% if block.settings.show_urgency and product.metafields.custom.in_carts_count != blank %}
      <div class="ai-product-top__urgency-{{ ai_gen_id }}">
        In {{ product.metafields.custom.in_carts_count }}+ carts
      </div>
    {% endif %}

    <div class="ai-product-top__price-section-{{ ai_gen_id }}">
      <div class="ai-product-top__price-wrapper-{{ ai_gen_id }}">
        <span class="ai-product-top__price-{{ ai_gen_id }}">
          {{ product.selected_or_first_available_variant.price | money }}
        </span>

        {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
          <span class="ai-product-top__compare-price-{{ ai_gen_id }}">
            {{ product.selected_or_first_available_variant.compare_at_price | money }}
          </span>

          {% assign discount_amount = product.selected_or_first_available_variant.compare_at_price | minus: product.selected_or_first_available_variant.price %}
          {% assign discount_percent = discount_amount | times: 100.0 | divided_by: product.selected_or_first_available_variant.compare_at_price | round %}

          <span class="ai-product-top__discount-badge-{{ ai_gen_id }}">
            -{{ discount_percent }}%
          </span>
        {% endif %}
      </div>

      {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
        {% assign discount_amount = product.selected_or_first_available_variant.compare_at_price | minus: product.selected_or_first_available_variant.price %}
        {% assign discount_percent = discount_amount | times: 100.0 | divided_by: product.selected_or_first_available_variant.compare_at_price | round %}

        <div class="ai-product-top__sale-line-{{ ai_gen_id }}">
          {{ discount_percent }}% off sale - {{ block.settings.sale_text }}
        </div>
      {% endif %}

      {% if block.settings.show_tax_text %}
        <div class="ai-product-top__tax-text-{{ ai_gen_id }}">
          {{ block.settings.tax_text }}
        </div>
      {% endif %}
    </div>

    <h1 class="ai-product-top__title-{{ ai_gen_id }}">
      {{ product.title }}
    </h1>
  </div>
</product-top-section-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductTopSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.startX = 0;
        this.currentX = 0;
        this.isDragging = false;
      }

      connectedCallback() {
        this.carousel = this.querySelector('.ai-product-top__carousel-wrapper-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-product-top__carousel-slide-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-product-top__dot-{{ ai_gen_id }}');
        this.wishlistBtn = this.querySelector('.ai-product-top__wishlist-btn-{{ ai_gen_id }}');
        this.shareBtn = this.querySelector('.ai-product-top__share-btn-{{ ai_gen_id }}');

        if (this.slides.length > 1) {
          this.setupCarousel();
        }

        if (this.wishlistBtn) {
          this.setupWishlist();
        }

        if (this.shareBtn) {
          this.setupShare();
        }
      }

      setupCarousel() {
        this.carousel.addEventListener('touchstart', this.handleTouchStart.bind(this));
        this.carousel.addEventListener('touchmove', this.handleTouchMove.bind(this));
        this.carousel.addEventListener('touchend', this.handleTouchEnd.bind(this));

        this.carousel.addEventListener('mousedown', this.handleMouseDown.bind(this));
        this.carousel.addEventListener('mousemove', this.handleMouseMove.bind(this));
        this.carousel.addEventListener('mouseup', this.handleMouseUp.bind(this));
        this.carousel.addEventListener('mouseleave', this.handleMouseUp.bind(this));
      }

      handleTouchStart(e) {
        this.startX = e.touches[0].clientX;
        this.isDragging = true;
      }

      handleTouchMove(e) {
        if (!this.isDragging) return;
        this.currentX = e.touches[0].clientX;
      }

      handleTouchEnd() {
        if (!this.isDragging) return;
        this.isDragging = false;

        const diff = this.startX - this.currentX;
        const threshold = 50;

        if (Math.abs(diff) > threshold) {
          if (diff > 0 && this.currentSlide < this.slides.length - 1) {
            this.currentSlide++;
          } else if (diff < 0 && this.currentSlide > 0) {
            this.currentSlide--;
          }
          this.updateCarousel();
        }
      }

      handleMouseDown(e) {
        this.startX = e.clientX;
        this.isDragging = true;
        this.carousel.style.cursor = 'grabbing';
      }

      handleMouseMove(e) {
        if (!this.isDragging) return;
        this.currentX = e.clientX;
      }

      handleMouseUp() {
        if (!this.isDragging) return;
        this.isDragging = false;
        this.carousel.style.cursor = 'grab';

        const diff = this.startX - this.currentX;
        const threshold = 50;

        if (Math.abs(diff) > threshold) {
          if (diff > 0 && this.currentSlide < this.slides.length - 1) {
            this.currentSlide++;
          } else if (diff < 0 && this.currentSlide > 0) {
            this.currentSlide--;
          }
          this.updateCarousel();
        }
      }

      updateCarousel() {
        const offset = -this.currentSlide * 100;
        this.carousel.style.transform = `translateX(${offset}%)`;

        this.dots.forEach(function(dot, index) {
          if (index === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        }.bind(this));
      }

      setupWishlist() {
        this.wishlistBtn.addEventListener('click', function() {
          this.wishlistBtn.classList.toggle('active');
        }.bind(this));
      }

      setupShare() {
        this.shareBtn.addEventListener('click', function() {
          if (navigator.share) {
            navigator.share({
              title: document.title,
              url: window.location.href
            });
          } else {
            const url = window.location.href;
            navigator.clipboard.writeText(url);
            alert('Link copied to clipboard!');
          }
        });
      }
    }

    customElements.define('product-top-section-{{ ai_gen_id }}', ProductTopSection{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product top section",
  "settings": [
    {
      "type": "header",
      "content": "Image carousel"
    },
    {
      "type": "checkbox",
