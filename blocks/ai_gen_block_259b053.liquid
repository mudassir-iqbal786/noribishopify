      "type": "color",
      "id": "action_button_bg",
      "label": "Action button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "action_button_color",
      "label": "Action button icon color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Urgency text"
    },
    {
      "type": "checkbox",
      "id": "show_urgency",
      "label": "Show urgency text",
      "info": "Requires product metafield: custom.in_carts_count (number)",
      "default": true
    },
    {
      "type": "color",
      "id": "urgency_color",
      "label": "Urgency text color",
      "default": "#d0473e"
    },
    {
      "type": "header",
      "content": "Price section"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "compare_price_color",
      "label": "Compare price color",
      "default": "#999999"
    },
    {
      "type": "color",
      "id": "sale_badge_bg",
      "label": "Sale badge background",
      "default": "#d0473e"
    },
    {
      "type": "color",
      "id": "sale_badge_color",
      "label": "Sale badge text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Sale line"
    },
    {
      "type": "text",
      "id": "sale_text",
      "label": "Sale text",
      "default": "Limited time sale"
    },
    {
      "type": "color",
      "id": "sale_text_color",
      "label": "Sale text color",
      "default": "#14854e"
    },
    {
      "type": "header",
      "content": "Tax text"
    },
    {
