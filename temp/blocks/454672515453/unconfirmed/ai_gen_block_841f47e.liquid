{% doc %}
  @prompt
    On the mobile product page, create two large prominent white circular buttons side by side with bold black icons inside. Share icon on the left, heart/wishlist icon on the right. The circles should be large (around 60px), with solid white background, subtle box shadow, and thick bold black SVG icons. Position them overlaid on the product image. Clean, minimal, prominent style like large white circle buttons floating over the product image.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-actions-{{ ai_gen_id }} {
    display: block;
    position: absolute;
    top: {{ block.settings.vertical_position }}%;
    right: {{ block.settings.horizontal_position }}px;
    z-index: 10;
    display: flex;
    gap: {{ block.settings.button_spacing }}px;
  }

  .ai-product-action-button-{{ ai_gen_id }} {
    width: {{ block.settings.button_size }}px;
    height: {{ block.settings.button_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.button_background }};
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: {{ block.settings.shadow_horizontal }}px {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
    transition: transform 0.2s ease;
    padding: 0;
  }

  .ai-product-action-button-{{ ai_gen_id }}:active {
    transform: scale(0.95);
  }

  .ai-product-action-button-{{ ai_gen_id }} svg {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    stroke: {{ block.settings.icon_color }};
    fill: none;
    stroke-width: {{ block.settings.icon_stroke_width }};
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-product-action-button-{{ ai_gen_id }}--wishlist.active svg {
    fill: {{ block.settings.icon_color }};
  }

  @media screen and (min-width: 750px) {
    .ai-product-actions-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<product-actions-{{ ai_gen_id }}
  class="ai-product-actions-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <button
    type="button"
    class="ai-product-action-button-{{ ai_gen_id }} ai-product-action-button-{{ ai_gen_id }}--share"
    aria-label="Share product"
    data-action="share"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
      <circle cx="18" cy="5" r="3"></circle>
      <circle cx="6" cy="12" r="3"></circle>
      <circle cx="18" cy="19" r="3"></circle>
      <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
      <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
    </svg>
  </button>

  <button
    type="button"
    class="ai-product-action-button-{{ ai_gen_id }} ai-product-action-button-{{ ai_gen_id }}--wishlist"
    aria-label="Add to wishlist"
    data-action="wishlist"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
    </svg>
  </button>
</product-actions-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductActions{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.shareButton = this.querySelector('[data-action="share"]');
        this.wishlistButton = this.querySelector('[data-action="wishlist"]');
        
        this.setupEventListeners();
        this.checkWishlistState();
      }

      setupEventListeners() {
        if (this.shareButton) {
          this.shareButton.addEventListener('click', () => this.handleShare());
        }

        if (this.wishlistButton) {
          this.wishlistButton.addEventListener('click', () => this.handleWishlist());
        }
      }

      handleShare() {
        const productUrl = window.location.href;
        const productTitle = document.querySelector('.product__title')?.textContent || 'Check out this product';

        if (navigator.share) {
          navigator.share({
            title: productTitle,
            url: productUrl
          }).catch(() => {});
        } else {
          this.fallbackShare(productUrl);
        }
      }

      fallbackShare(url) {
        const tempInput = document.createElement('input');
        tempInput.value = url;
        document.body.appendChild(tempInput);
        tempInput.select();
        document.execCommand('copy');
        document.body.removeChild(tempInput);
        
        this.showToast('Link copied to clipboard');
      }

      handleWishlist() {
        const productHandle = window.location.pathname.split('/').pop();
        const isActive = this.wishlistButton.classList.contains('active');

        if (isActive) {
          this.removeFromWishlist(productHandle);
        } else {
          this.addToWishlist(productHandle);
        }
      }

      addToWishlist(handle) {
        let wishlist = this.getWishlist();
        if (!wishlist.includes(handle)) {
          wishlist.push(handle);
          localStorage.setItem('wishlist', JSON.stringify(wishlist));
          this.wishlistButton.classList.add('active');
          this.showToast('Added to wishlist');
        }
      }

      removeFromWishlist(handle) {
        let wishlist = this.getWishlist();
        wishlist = wishlist.filter(item => item !== handle);
        localStorage.setItem('wishlist', JSON.stringify(wishlist));
        this.wishlistButton.classList.remove('active');
        this.showToast('Removed from wishlist');
      }

      getWishlist() {
        const wishlist = localStorage.getItem('wishlist');
        return wishlist ? JSON.parse(wishlist) : [];
      }

      checkWishlistState() {
        const productHandle = window.location.pathname.split('/').pop();
        const wishlist = this.getWishlist();
        
        if (wishlist.includes(productHandle)) {
          this.wishlistButton.classList.add('active');
        }
      }

      showToast(message) {
        const existingToast = document.querySelector('.ai-toast-{{ ai_gen_id }}');
        if (existingToast) {
          existingToast.remove();
        }

        const toast = document.createElement('div');
        toast.className = 'ai-toast-{{ ai_gen_id }}';
        toast.textContent = message;
        toast.style.cssText = 'position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); background: #111; color: #fff; padding: 12px 24px; border-radius: 8px; z-index: 9999; font-size: 14px;';
        
        document.body.appendChild(toast);
        
        setTimeout(() => {
          toast.remove();
        }, 2000);
      }
    }

    customElements.define('product-actions-{{ ai_gen_id }}', ProductActions{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product action buttons",
  "settings": [
    {
      "type": "header",
      "content": "Position"
    },
    {
      "type": "range",
      "id": "vertical_position",
      "label": "Vertical position",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "%",
      "default": 10
    },
    {
      "type": "range",
      "id": "horizontal_position",
      "label": "Horizontal position",
      "min": 10,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "range",
      "id": "button_size",
      "label": "Button size",
      "min": 40,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "button_spacing",
      "label": "Space between buttons",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Icon style"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 20,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "icon_stroke_width",
      "label": "Icon thickness",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Shadow"
    },
    {
      "type": "range",
      "id": "shadow_horizontal",
      "label": "Horizontal offset",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "shadow_vertical",
      "label": "Vertical offset",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "shadow_blur",
      "label": "Blur",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "label": "Opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.1
    }
  ],
  "presets": [
    {
      "name": "Product action buttons"
    }
  ]
}
{% endschema %}
