{% doc %}
  @prompt
    Update the product page layout to be similar to Etsy's product page style, but adapted for a single brand store (no marketplace/seller elements). Specifically:
    
    1. Description Section: Place below product info with clean typography. Add a "Show more" toggle if the description is long.
    
    2. Delivery / Shipping Info Section: Show estimated delivery date clearly (e.g., "Arrives by Apr 10–17"), with shipping details in a simple, clean card format with an icon.
    
    3. Purchase Protection / Trust Section: Add a small trust badge section with an icon and text like "Secure checkout & buyer protection".
    
    4. Reviews Section: Show star rating summary at the top, display customer reviews in clean cards, include rating breakdown by star level.
    
    5. Layout & Style: Keep everything minimal and clean with proper spacing between sections. Fully responsive and premium look. No seller profile, shop name, seller ratings, or "More from this shop" sections.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-etsy-product-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-etsy-section-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.section_spacing }}px;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.section_background }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-etsy-section-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.section_title_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
  }

  .ai-etsy-description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    font-size: {{ block.settings.text_size }}px;
  }

  .ai-etsy-description-content-{{ ai_gen_id }} {
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .ai-etsy-description-content-{{ ai_gen_id }}.collapsed {
    max-height: 150px;
  }

  .ai-etsy-description-content-{{ ai_gen_id }}.expanded {
    max-height: none;
  }

  .ai-etsy-show-more-btn-{{ ai_gen_id }} {
    background: none;
    border: none;
    color: {{ block.settings.link_color }};
    font-size: {{ block.settings.text_size }}px;
    font-weight: 500;
    cursor: pointer;
    padding: 8px 0;
    margin-top: 8px;
    text-decoration: underline;
  }

  .ai-etsy-show-more-btn-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-etsy-shipping-card-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: {{ block.settings.card_padding }}px;
    background-color: {{ block.settings.card_background }};
    border: 1px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
  }

  .ai-etsy-shipping-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    color: {{ block.settings.icon_color }};
  }

  .ai-etsy-shipping-content-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-etsy-shipping-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0 0 4px 0;
  }

  .ai-etsy-shipping-date-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px 0;
  }

  .ai-etsy-shipping-details-{{ ai_gen_id }} {
    font-size: calc({{ block.settings.text_size }}px - 1px);
    color: {{ block.settings.secondary_text_color }};
    margin: 0;
  }

  .ai-etsy-trust-badges-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-etsy-trust-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-etsy-trust-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: {{ block.settings.trust_icon_color }};
  }

  .ai-etsy-trust-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-etsy-reviews-summary-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid {{ block.settings.card_border_color }};
  }

  .ai-etsy-rating-number-{{ ai_gen_id }} {
    font-size: 32px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
  }

  .ai-etsy-rating-details-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-etsy-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    margin-bottom: 4px;
  }

  .ai-etsy-star-{{ ai_gen_id }} {
    width: 18px;
    height: 18px;
    color: {{ block.settings.star_color }};
  }

  .ai-etsy-star-empty-{{ ai_gen_id }} {
    color: {{ block.settings.star_empty_color }};
  }

  .ai-etsy-review-count-{{ ai_gen_id }} {
    font-size: calc({{ block.settings.text_size }}px - 1px);
    color: {{ block.settings.secondary_text_color }};
  }

  .ai-etsy-rating-breakdown-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-etsy-rating-row-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }

  .ai-etsy-rating-label-{{ ai_gen_id }} {
    font-size: calc({{ block.settings.text_size }}px - 1px);
    color: {{ block.settings.text_color }};
    min-width: 60px;
  }

  .ai-etsy-rating-bar-bg-{{ ai_gen_id }} {
    flex-grow: 1;
    height: 8px;
    background-color: {{ block.settings.bar_background }};
    border-radius: 4px;
    overflow: hidden;
  }

  .ai-etsy-rating-bar-fill-{{ ai_gen_id }} {
    height: 100%;
    background-color: {{ block.settings.bar_fill_color }};
    transition: width 0.3s ease;
  }

  .ai-etsy-rating-percent-{{ ai_gen_id }} {
    font-size: calc({{ block.settings.text_size }}px - 1px);
    color: {{ block.settings.secondary_text_color }};
    min-width: 40px;
    text-align: right;
  }

  .ai-etsy-review-card-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    background-color: {{ block.settings.card_background }};
    border: 1px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    margin-bottom: 16px;
  }

  .ai-etsy-review-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .ai-etsy-reviewer-avatar-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: {{ block.settings.avatar_background }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    color: {{ block.settings.avatar_text_color }};
    font-size: 16px;
  }

  .ai-etsy-reviewer-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-etsy-reviewer-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0 0 2px 0;
  }

  .ai-etsy-review-date-{{ ai_gen_id }} {
    font-size: calc({{ block.settings.text_size }}px - 2px);
    color: {{ block.settings.secondary_text_color }};
  }

  .ai-etsy-review-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
    margin-bottom: 8px;
  }

  .ai-etsy-review-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-etsy-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: {{ block.settings.secondary_text_color }};
    font-size: {{ block.settings.text_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-etsy-product-layout-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-etsy-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.7 }}px;
      margin-bottom: {{ block.settings.section_spacing | times: 0.7 }}px;
    }

    .ai-etsy-rating-number-{{ ai_gen_id }} {
      font-size: 24px;
    }
  }
{% endstyle %}

<etsy-product-layout-{{ ai_gen_id }}
  class="ai-etsy-product-layout-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.show_description %}
    <div class="ai-etsy-section-{{ ai_gen_id }}">
      <h2 class="ai-etsy-section-title-{{ ai_gen_id }}">{{ block.settings.description_title }}</h2>
      <div class="ai-etsy-description-{{ ai_gen_id }}">
        <div
          class="ai-etsy-description-content-{{ ai_gen_id }} collapsed"
          data-description-content
        >
          {% if product.description != blank %}
            {{ product.description }}
          {% else %}
            <p>{{ block.settings.placeholder_description }}</p>
          {% endif %}
        </div>
        <button
          class="ai-etsy-show-more-btn-{{ ai_gen_id }}"
          data-show-more-btn
          style="display: none;"
        >
          {{ block.settings.show_more_text }}
        </button>
      </div>
    </div>
  {% endif %}

  {% if block.settings.show_shipping %}
    <div class="ai-etsy-section-{{ ai_gen_id }}">
      <h2 class="ai-etsy-section-title-{{ ai_gen_id }}">{{ block.settings.shipping_title }}</h2>
      <div class="ai-etsy-shipping-card-{{ ai_gen_id }}">
        <div class="ai-etsy-shipping-icon-{{ ai_gen_id }}">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="1" y="3" width="15" height="13"></rect>
            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
            <circle cx="5.5" cy="18.5" r="2.5"></circle>
            <circle cx="18.5" cy="18.5" r="2.5"></circle>
          </svg>
        </div>
        <div class="ai-etsy-shipping-content-{{ ai_gen_id }}">
          <p class="ai-etsy-shipping-title-{{ ai_gen_id }}">{{ block.settings.delivery_label }}</p>
          <p class="ai-etsy-shipping-date-{{ ai_gen_id }}">
            {{ block.settings.estimated_delivery }}
          </p>
          <p class="ai-etsy-shipping-details-{{ ai_gen_id }}">
            {{ block.settings.shipping_details }}
          </p>
        </div>
      </div>
    </div>
  {% endif %}

  {% if block.settings.show_trust %}
    <div class="ai-etsy-section-{{ ai_gen_id }}">
      <h2 class="ai-etsy-section-title-{{ ai_gen_id }}">{{ block.settings.trust_title }}</h2>
      <div class="ai-etsy-trust-badges-{{ ai_gen_id }}">
        {% if block.settings.trust_item_1 != blank %}
          <div class="ai-etsy-trust-item-{{ ai_gen_id }}">
            <div class="ai-etsy-trust-icon-{{ ai_gen_id }}">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                <path d="M9 12l2 2 4-4"></path>
              </svg>
            </div>
            <p class="ai-etsy-trust-text-{{ ai_gen_id }}">{{ block.settings.trust_item_1 }}</p>
          </div>
        {% endif %}

        {% if block.settings.trust_item_2 != blank %}
          <div class="ai-etsy-trust-item-{{ ai_gen_id }}">
            <div class="ai-etsy-trust-icon-{{ ai_gen_id }}">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
              </svg>
            </div>
            <p class="ai-etsy-trust-text-{{ ai_gen_id }}">{{ block.settings.trust_item_2 }}</p>
          </div>
        {% endif %}

        {% if block.settings.trust_item_3 != blank %}
          <div class="ai-etsy-trust-item-{{ ai_gen_id }}">
            <div class="ai-etsy-trust-icon-{{ ai_gen_id }}">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
            </div>
            <p class="ai-etsy-trust-text-{{ ai_gen_id }}">{{ block.settings.trust_item_3 }}</p>
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {% if block.settings.show_reviews %}
    <div class="ai-etsy-section-{{ ai_gen_id }}">
      <h2 class="ai-etsy-section-title-{{ ai_gen_id }}">{{ block.settings.reviews_title }}</h2>

      {% if product.metafields.reviews.rating.value != blank %}
        <div class="ai-etsy-reviews-summary-{{ ai_gen_id }}">
          <div class="ai-etsy-rating-number-{{ ai_gen_id }}">
            {{ product.metafields.reviews.rating.value }}
          </div>
          <div class="ai-etsy-rating-details-{{ ai_gen_id }}">
            <div class="ai-etsy-stars-{{ ai_gen_id }}">
              {% assign rating = product.metafields.reviews.rating.value %}
              {% for i in (1..5) %}
                {% if i <= rating %}
                  <svg
                    class="ai-etsy-star-{{ ai_gen_id }}"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                  >
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                  </svg>
                {% else %}
                  <svg
                    class="ai-etsy-star-{{ ai_gen_id }} ai-etsy-star-empty-{{ ai_gen_id }}"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                  >
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                  </svg>
                {% endif %}
              {% endfor %}
            </div>
            <p class="ai-etsy-review-count-{{ ai_gen_id }}">
              Based on {{ product.metafields.reviews.rating_count.value | default: 0 }} reviews
            </p>
          </div>
        </div>

        <div class="ai-etsy-rating-breakdown-{{ ai_gen_id }}">
          {% assign breakdown = block.settings.rating_breakdown | split: ',' %}
          {% for i in (1..5) %}
            {% assign index = 5 | minus: i %}
            {% assign percent = breakdown[index] | default: 0 %}
            <div class="ai-etsy-rating-row-{{ ai_gen_id }}">
              <span class="ai-etsy-rating-label-{{ ai_gen_id }}">{{ 5 | minus: i | plus: 1 }} stars</span>
              <div class="ai-etsy-rating-bar-bg-{{ ai_gen_id }}">
                <div
                  class="ai-etsy-rating-bar-fill-{{ ai_gen_id }}"
                  style="width: {{ percent }}%;"
                ></div>
              </div>
              <span class="ai-etsy-rating-percent-{{ ai_gen_id }}">{{ percent }}%</span>
            </div>
          {% endfor %}
        </div>
      {% endif %}

      {% if product.metafields.reviews.reviews.value != blank %}
        {% assign reviews = product.metafields.reviews.reviews.value %}
        {% for review in reviews limit: block.settings.reviews_to_show %}
          <div class="ai-etsy-review-card-{{ ai_gen_id }}">
            <div class="ai-etsy-review-header-{{ ai_gen_id }}">
              <div class="ai-etsy-reviewer-avatar-{{ ai_gen_id }}">
                {{ review.author | slice: 0 | upcase }}
              </div>
              <div class="ai-etsy-reviewer-info-{{ ai_gen_id }}">
                <p class="ai-etsy-reviewer-name-{{ ai_gen_id }}">{{ review.author }}</p>
                <span class="ai-etsy-review-date-{{ ai_gen_id }}">{{ review.created_at | date: '%B %d, %Y' }}</span>
              </div>
            </div>
            <div class="ai-etsy-review-stars-{{ ai_gen_id }}">
              {% for i in (1..5) %}
                {% if i <= review.rating %}
                  <svg
                    class="ai-etsy-star-{{ ai_gen_id }}"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    width="16"
                    height="16"
                  >
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                  </svg>
                {% else %}
                  <svg
                    class="ai-etsy-star-{{ ai_gen_id }} ai-etsy-star-empty-{{ ai_gen_id }}"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    width="16"
                    height="16"
                  >
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                  </svg>
                {% endif %}
              {% endfor %}
            </div>
            <p class="ai-etsy-review-text-{{ ai_gen_id }}">{{ review.body }}</p>
          </div>
        {% endfor %}
      {% else %}
        <div class="ai-etsy-empty-state-{{ ai_gen_id }}">
          <p>No reviews yet. Be the first to review this product!</p>
        </div>
      {% endif %}
    </div>
  {% endif %}
</etsy-product-layout-{{ ai_gen_id }}>

<script>
  (function() {
    class EtsyProductLayout{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initShowMore();
      }

      initShowMore() {
        const content = this.querySelector('[data-description-content]');
        const button = this.querySelector('[data-show-more-btn]');

        if (!content || !button) return;

        if (content.scrollHeight > 150) {
          button.style.display = 'block';

          button.addEventListener('click', () => {
            const isCollapsed = content.classList.contains('collapsed');

            if (isCollapsed) {
              content.classList.remove('collapsed');
              content.classList.add('expanded');
              button.textContent = '{{ block.settings.show_less_text }}';
            } else {
              content.classList.remove('expanded');
              content.classList.add('collapsed');
              button.textContent = '{{ block.settings.show_more_text }}';
            }
          });
        }
      }
    }

    customElements.define('etsy-product-layout-{{ ai_gen_id }}', EtsyProductLayout{{ ai_gen_id }});
  })();
</script>

{% schema %}
