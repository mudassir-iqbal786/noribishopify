      "default": true
    },
    {
      "type": "text",
      "id": "trust_title",
      "label": "Title",
      "default": "Purchase Protection"
    },
    {
      "type": "text",
      "id": "trust_item_1",
      "label": "Trust item 1",
      "default": "Secure checkout & buyer protection"
    },
    {
      "type": "text",
      "id": "trust_item_2",
      "label": "Trust item 2",
      "default": "SSL encrypted payment processing"
    },
