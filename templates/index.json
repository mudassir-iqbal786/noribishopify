          }
        },
        "testimonials_items_R8fY4A": {
          "type": "testimonials_items",
          "settings": {
            "author_image": "shopify://shop_images/Image_1776419493181.jpg",
            "author_rating": 5,
            "author_text": "<p>I am absolutely in love with this dress. The design is stunning and exactly as shown in the pictures. The quality of the fabric and the detailing is truly impressive, and you can tell a lot of care went into making it. The fit is very flattering and gives such an elegant, feminine look. What I really loved is how unique and premium it feels. It photographs beautifully and looks even better in person. I received so many compliments when wearing it, and it made me feel very confident and special. Overall, I am extremely happy with this purchase and would highly recommend it to anyone looking for something elegant, unique, and high quality.</p>",
            "select_product": "white-lace-corset-wedding-dress-sheer-bridal-gown-fairy-style",
            "author_name": "June"
          }
        }
