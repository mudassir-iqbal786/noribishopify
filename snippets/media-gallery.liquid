{% liquid
  assign layout = 'grid'

  if desktop_layout == 'thumbnail_left' or desktop_layout == 'thumbnail_bottom' or desktop_layout == 'hidden_thumbnail'
    assign layout = 'thumbnail'
  elsif desktop_layout == 'stack'
    assign layout = 'stack'
  else
    assign layout = 'grid'
  endif
  assign zoom_option = 'inner-1'
  assign mobile_options = 'hidden_thumbnail'
  if section_st != null
    assign mobile_options = section_st.mobile_options
  endif
  assign image_zoom = 'no_zoom'
  if section_st != null
    assign image_zoom = section_st.image_zoom
  endif
  if image_zoom == 'external_zoom'
    assign zoom_option = 'external'
  elsif image_zoom == 'inner_zoom_circle'
    assign zoom_option = 'inner-2'
  endif
  if type == 'single' or type == 'quickview'
    assign image_zoom = 'no_zoom'
    if type == 'quickview'
      assign layout = 'thumbnail'
      assign desktop_layout = 'hidden_thumbnail'
    endif
  endif
  assign enable_sticky_content_on_desktop = section_st.enable_sticky_content_on_desktop
  assign image_list = ''
  assign filtered_images = ''
  assign product_ar = false
  assign class_prodcut_mobile = ''
  assign show_mobile_wishlist = false
  assign show_mobile_share = false
  assign wishlist = pages.wishlist
  assign action_when_click_added_wishlist = theme_st.action_when_click_added_wishlist
  assign share_url = product.selected_variant.url | default: product.url | prepend: request.origin
  for image in images
    if image.media_type == 'model'
      assign product_ar = true
    endif
  endfor
  for block in section.blocks
    if block.type == 'buy_buttons' and block.settings.show_wishlist == true
      assign show_mobile_wishlist = true
    endif
    if block.type == 'product_addons' and block.settings.show_share == true
      assign show_mobile_share = true
    endif
  endfor
  if action_when_click_added_wishlist == blank
    assign action_when_click_added_wishlist = 'go_to_page'
  endif
  if wishlist == empty
    assign action_when_click_added_wishlist = 'remove'
  endif
%}
{% for image in images %}
  {% if image.alt == 'image-360' and image.media_type == 'image' %}
    {% capture filtered_images %}{{ filtered_images }}{{ image.preview_image | image_url }},{% endcapture %}
  {% endif %}
{% endfor %}
{% assign filtered_images = filtered_images | split: ',' | compact %}
{% for image in filtered_images %}
  {% capture image_json %}"{{ image }}"{%- unless forloop.last -%},{%- endunless -%}{% endcapture %}
  {% capture image_list %}{{ image_list }}{{ image_json }}{% endcapture %}
{% endfor %}
{% if mobile_options == 'hidden_thumbnail' or desktop_layout == 'hidden_thumbnail' %}
  {% if  product_ar or image_list.size != 0 %}
    {% assign class_prodcut_mobile = 'show-on-mobile' %}
  {% endif %}
{% endif %}
<media-gallery
  class="block{% if enable_sticky_content_on_desktop %} sticky top-30{% endif %}"
  data-layout="{{ layout }}"
>
  {% if type != 'single' and type != 'quickview' %}
    <zoom-action
      class="block"
      data-type="{{ image_zoom }}"
      {% if zoom_type != 'open_lightbox' and zoom_type != 'no_zoom' %}
        data-zoom-option="{{ zoom_option }}"
      {% endif %}
    >
  {% endif %}
  {% comment %} Case product has more than one media {% endcomment %}
  {% case layout %}
    {% when 'thumbnail' %}
      {% comment %} Case carousel layout {% endcomment %}
      <slide-with-thumbs
        class="block relative {% if desktop_layout == 'thumbnail_left' %}justify-content-right {{ desktop_layout }} flex-md gap-10 overflow-hidden{% endif %}"
        data-section-id="{{ section.id }}"
        data-initial-slide="{{ position_index | default: 0 }}"
        data-effect="slide"
        data-speed="500"
        data-mobile-spacing="0"
        data-mobile="1"
        data-tablet="1"
        data-desktop="1"
        data-mobile-pagination="bullets"
        data-thumb-direction="{% if desktop_layout == 'thumbnail_left' %}vertical{% else %}horizontal{% endif %}"
        data-thumb-slides-per-view="4"
        data-thumb-mobile-slides-per-view="2"
        {%- if type == 'quickview' -%}
          data-nothumb="true"
        {%- endif -%}
        {% if desktop_layout == 'thumbnail_left' %}
          style="--col-gap: 1rem; --col-gap-desktop: 1rem;"
        {% endif %}
        data-auto-play-video="{{ section_st.enable_video_autoplay }}"
      >
        {%- if type == 'quickview' -%}
          {%- render 'swiper-navigation', class: 'original-style' -%}
        {% endif %}
        {% if type != 'quickview' %}
          {% if show_mobile_wishlist == true or show_mobile_share == true %}
            <div class="product-gallery-mobile-actions hidden-md">
              {% if show_mobile_wishlist == true %}
                <button-wishlist
                  tabindex="0"
                  class="product-gallery-mobile-action product-item__button pointer product-item__button-wishlist btn-hover transition bg-white rounded-50 border inline-flex content-center"
                  data-product-id="{{ product.id }}"
                  data-action="{{ action_when_click_added_wishlist }}"
                  data-tooltip-remove="{{ 'products.product.actions.wishlist.remove' | t }}"
                  data-tooltip-add="{{ 'products.product.actions.wishlist.add' | t }}"
                  data-tooltip-redirect="{{ 'products.product.actions.wishlist.redirect' | t }}"
                  aria-label="{{ 'products.product.actions.wishlist.add' | t }}"
                >
                  <svg width="18" height="16" fill="none" aria-hidden="true">
                    <use href="#icon-wishlist"></use>
                  </svg>
                </button-wishlist>
              {% endif %}
              {% if show_mobile_share == true %}
                <mobile-gallery-share
                  id="MobileShare-{{ section.id }}"
                  class="product-gallery-mobile-share"
                  data-url="{{ share_url }}"
                  data-title="{{ product.title | escape }}"
                >
                  <button
                    type="button"
                    class="product-gallery-mobile-action pointer btn-reset inline-flex content-center bg-white rounded-50 border"
                    aria-label="{{ 'products.product.addons.share.share' | t }}"
                  >
                    <svg width="18" height="18" fill="none" aria-hidden="true">
                      <path fill="currentColor" d="M12.617 13.233a1.075 1.075 0 0 0-.094.234 1.331 1.331 0 0 0-.023.258c0 .156.026.302.078.438.06.13.141.24.243.336.094.102.206.183.336.242.136.052.282.079.438.079.156 0 .297-.027.422-.079.136-.06.251-.14.344-.242a1.08 1.08 0 0 0 .234-.336 1.079 1.079 0 0 0 0-.86 1.08 1.08 0 0 0-.234-.343 1.08 1.08 0 0 0-.344-.234 1.078 1.078 0 0 0-.86 0 1.107 1.107 0 0 0-.335.234l-.079.078a.341.341 0 0 0-.062.094c0 .01-.005.018-.016.024-.008.009-.013.018-.015.03l-.024.024a.1.1 0 0 1-.015.04Zm.055-6.593c.015.036.036.07.062.102a.443.443 0 0 0 .094.094c.094.102.205.183.336.242.136.052.282.078.438.078.156 0 .297-.026.422-.078.136-.06.251-.141.344-.243a1.03 1.03 0 0 0 .234-.344 1.046 1.046 0 0 0 0-.844.998.998 0 0 0-.234-.359 1.113 1.113 0 0 0-.344-.234 1.078 1.078 0 0 0-.86 0 1.159 1.159 0 0 0-.335.234 1.163 1.163 0 0 0-.243.359 1.132 1.132 0 0 0-.078.422c0 .094.008.183.023.266.026.086.06.167.102.243v.024c.008 0 .013.005.015.015.009 0 .014.005.016.016l.015.015Zm-4.72 2.672a.674.674 0 0 0-.062-.102.443.443 0 0 0-.094-.094 1.08 1.08 0 0 0-.344-.234 1.078 1.078 0 0 0-.86 0 1.108 1.108 0 0 0-.336.234 1.162 1.162 0 0 0-.242.36 1.095 1.095 0 0 0-.079.413c0 .156.026.302.079.438.06.13.14.245.242.344a1.075 1.075 0 0 0 1.195.234c.138-.06.256-.138.352-.234l.09-.094a.503.503 0 0 0 .067-.117h.015c0-.009.005-.018.016-.024.008-.009.013-.018.015-.031a.84.84 0 0 0 .094-.242c.026-.094.04-.19.04-.282 0-.094-.014-.185-.04-.274a.84.84 0 0 0-.094-.242c0-.008-.005-.013-.015-.016V9.46h-.016c0-.009-.005-.018-.015-.03Zm3.54-2.66a3.352 3.352 0 0 1-.064-.284 2.198 2.198 0 0 1 .141-1.164c.12-.265.278-.495.474-.691.195-.197.426-.35.69-.461a2.116 2.116 0 0 1 1.703 0c.273.11.508.264.703.46.197.197.35.427.461.692.12.265.18.551.18.86 0 .299-.06.58-.18.845a2.133 2.133 0 0 1-.46.691 2.162 2.162 0 0 1-1.548.64 2.18 2.18 0 0 1-.86-.168 2.313 2.313 0 0 1-.691-.473L9.95 9.3c.026.094.047.192.063.297a1.866 1.866 0 0 1 0 .601 2.97 2.97 0 0 1-.063.297l2.906 1.687v-.016c.197-.196.427-.349.691-.46a2.116 2.116 0 0 1 1.703 0c.273.11.508.264.703.46.197.197.35.432.461.704a2.116 2.116 0 0 1 0 1.703 2.134 2.134 0 0 1-.46.691 2.18 2.18 0 0 1-.704.461 2.116 2.116 0 0 1-1.703 0 2.133 2.133 0 0 1-.691-.46 2.166 2.166 0 0 1-.474-.692 2.26 2.26 0 0 1-.168-.859c0-.102.008-.2.024-.297.017-.102.038-.205.063-.305l-2.906-1.688v.016a2.163 2.163 0 0 1-1.547.64 2.18 2.18 0 0 1-.86-.167 2.312 2.312 0 0 1-.691-.474 2.262 2.262 0 0 1-.473-.69 2.2 2.2 0 0 1-.167-.86c0-.299.055-.58.167-.843.12-.265.278-.495.473-.692.197-.196.427-.35.691-.46a2.116 2.116 0 0 1 1.703 0c.273.11.508.264.703.46l2.905-1.687Z"></path>
                    </svg>
                  </button>
                </mobile-gallery-share>
              {% endif %}
            </div>
          {% endif %}
        {% endif %}
        <div class="media-main-swiper skeleton-loading">
          <div class="swiper-wrapper-preview swiper">
            <div class="swiper-wrapper">
              {% assign is_shopable_video = false %}
              {% if section_st == null %}
                {% assign is_shopable_video = true %}
              {% endif %}
              {% render 'product-media-layout',
                images: images,
                section_st: section_st,
                theme_st: theme_st,
                section: section,
                custom_class: ' swiper-slide',
                is_thumbnail: is_shopable_video,
                zoom_type: image_zoom,
                type: type
              %}
            </div>
            {%- render 'swiper-navigation', class: 'main-slide__navigation', class_prodcut_mobile: class_prodcut_mobile -%}
          </div>
        </div>
        {% comment %} {%- render 'swiper-navigation' -%} {% endcomment %}
        {% if desktop_layout == 'thumbnail_left' or desktop_layout == 'thumbnail_bottom' %}
          <div class="media-thumb-swiper{% if desktop_layout == 'thumbnail_left' %} mt-10{% endif %}{% if mobile_options == 'hidden_thumbnail' %} thumbnail-slide__mobile--hidden{% endif %}">
            <div
              class="thumbnail-slide swiper{% if desktop_layout == 'thumbnail_bottom' %} mt-10 thumb-bottom{% endif %}"
              {% if desktop_layout == 'thumbnail_bottom' %}
                style="--gap: 15px;"
              {% endif %}
            >
              <div class="swiper-wrapper">
                {% render 'product-media-layout',
                  images: images,
                  section_st: section_st,
                  theme_st: theme_st,
                  section: section,
                  custom_class: ' swiper-slide',
                  zoom_type: 'no_zoom',
                  is_thumbnail: true,
                  type: type
                %}
              </div>
            </div>
          </div>
          {% if is_shopable_video == false and desktop_layout == 'thumbnail_left' %}
            <div
              class="swiper-pagination product-gallery-pagination hidden-md"
            ></div>
          {% elsif section_st.mobile_options == 'hidden_thumbnail' and is_shopable_video == false %}
            <div
              class="swiper-pagination hidden-md"
            ></div>
          {% endif %}
        {% else %}
          {% if is_shopable_video == false %}
            <div
              class="swiper-pagination hidden-md"
            ></div>
          {% endif %}
        {% endif %}
      </slide-with-thumbs>
    {% when 'grid' %}
      {% comment %} Case grid layout {% endcomment %}
      <div
        id="GalleryViewer-{{ section.id }}"
        class="grid grid-cols gap grid_scroll"
        style="{%- if desktop_layout == 'grid_1_column' -%}--col-number: 1.2;--col-desktop: 1;--col-tablet: 1;--col-gap: 10px;{%- else -%}--col-number: 1.2;--col-tablet: 2;--col-desktop: 2;--col-gap: 10px;{%- endif -%}"
      >
        {% render 'product-media-layout',
          images: images,
          section_st: section_st,
          theme_st: theme_st,
          section: section,
          zoom_type: image_zoom,
          type: type,
          layout: layout
        %}
      </div>
    {% else %}
      {% comment %} Case stack layout {% endcomment %}
      <div
        class="stacked gap-10 grid grid-cols grid_scroll"
        id="GalleryViewer-{{ section.id }}"
        style="--col-number: 1.2;"
      >
        {% render 'product-media-layout',
          images: images,
          section_st: section_st,
          theme_st: theme_st,
          section: section,
          zoom_type: image_zoom,
          type: type,
          layout: layout
        %}
      </div>
  {% endcase %}
  {% comment %} Case product has only one image {% endcomment %}
  {% comment %}
    {%- if images.size == 1 -%}
      {% render 'product-media-layout',
        images: images,
        section_st: section_st,
        section: section,
        theme_st: theme_st,
        zoom_type: image_zoom,
        type: type
      %}
    {%- endif -%}
  {% endcomment %}
  {% if type != 'single' and type != 'quickview' %}
    </zoom-action>
  {% endif %}
</media-gallery>
